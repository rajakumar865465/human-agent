# Vision AI Provider
# Supports any OpenAI-compatible endpoint (OpenAI, Azure, local LM Studio, etc.)
VISION_PROVIDER_NAME=OpenAI
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...

# Vision model used for screen analysis
# Must be a vision-capable model: gpt-4o, gpt-4.1, claude-3-5-sonnet-20241022, etc.
VISION_MODEL=gpt-4o

# Optional: Anthropic API key (if using Claude as the vision model)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Dashboard port (default 8080)
# DASHBOARD_PORT=8080

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
